# Server config
PORT=4000
NODE_ENV=development

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kota_associates

# CORS
ALLOWED_ORIGIN=http://localhost:5173

# Admin API key (for GET /api/appointments and /api/contacts)
ADMIN_API_KEY=change-me-to-a-long-random-string

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Kota Associates <kotaassociatesworks@gmail.com>"
ADMIN_NOTIFY_EMAIL=kotaassociatesworks@gmail.com
